        </geometry>
        <surface>
          <contact>
            <collide_bitmask>0xFD</collide_bitmask>
            <ode>
              <max_vel>10</max_vel>
              <min_depth>0.01</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>
      
      <collision name="wings_collision">
        <pose>-0.01 0 0.07 0 0 0</pose>
