<?xml version="1.0"?>
<sdf version="1.9">
  <model name="cessna_aircraft">
    <pose>0 0 0.246 0 0 0</pose>
    
    <link name="base_link">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.197563</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.1458929</iyy>
          <iyz>0</iyz>
